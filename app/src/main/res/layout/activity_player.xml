<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:show_buffering="when_playing"
        app:surface_type="surface_view"
        app:show_subtitle_button="true" />

    <!-- Channel info overlay (top) -->
    <LinearLayout
        android:id="@+id/overlayInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="@color/overlay_bg"
        android:padding="@dimen/overlay_padding"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvChannelName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChannelCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- On-screen controls (bottom) -->
    <LinearLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/overlay_bg"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <!-- Seek bar row -->
        <LinearLayout
            android:id="@+id/seekBarRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:minWidth="50dp" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:max="1000"
                android:progressTint="@color/red"
                android:thumbTint="@color/red"
                android:progressBackgroundTint="@color/text_dim"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:minWidth="50dp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Buttons row - large, clear icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Rewind 10s -->
            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_rewind_10"
                android:background="@drawable/bg_player_button"
                android:contentDescription="Rewind 10s"
                android:layout_marginEnd="20dp"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Play / Pause (bigger) -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_pause"
                android:background="@drawable/bg_player_button"
                android:contentDescription="Play/Pause"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Forward 10s -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_forward_10"
                android:background="@drawable/bg_player_button"
                android:contentDescription="Forward 10s"
                android:layout_marginStart="20dp"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Subtitles CC -->
            <ImageButton
                android:id="@+id/btnSubtitles"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_subtitles"
                android:background="@drawable/bg_player_button"
                android:contentDescription="Subtitles"
                android:layout_marginStart="40dp"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Picture in Picture -->
            <ImageButton
                android:id="@+id/btnPip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_pip"
                android:background="@drawable/bg_player_button"
                android:contentDescription="Picture in Picture"
                android:layout_marginStart="16dp"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/red" />

    <!-- Error text -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/player_error"
        android:textColor="@color/red"
        android:textSize="18sp"
        android:visibility="gone" />

</FrameLayout>

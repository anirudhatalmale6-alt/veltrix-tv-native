<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="12dp"
    android:background="@drawable/bg_channel_list_item"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Channel number -->
    <TextView
        android:id="@+id/tvChannelNumber"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_dim"
        android:textSize="14sp"
        android:gravity="center"
        android:text="1" />

    <!-- Channel logo -->
    <ImageView
        android:id="@+id/ivChannelIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="4dp"
        android:scaleType="fitCenter"
        android:contentDescription="Channel icon" />

    <!-- Channel name + EPG info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/tvChannelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvEpgNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Playing indicator -->
    <ImageView
        android:id="@+id/ivPlaying"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:src="@android:drawable/ic_media_play"
        android:tint="@color/red"
        android:visibility="gone"
        android:contentDescription="Playing" />

</LinearLayout>

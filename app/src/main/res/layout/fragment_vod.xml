<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/categoryContainer"
        android:layout_width="@dimen/category_width"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@color/surface"
            android:clipToPadding="false"
            android:padding="8dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/surface_light" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Movie detail panel (top) -->
            <FrameLayout
                android:id="@+id/detailPanel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone">

                <!-- Backdrop image -->
                <ImageView
                    android:id="@+id/ivBackdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Backdrop" />

                <!-- Gradient overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#BB0D0D1A" />

                <!-- Movie info overlay -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/tvMovieTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <!-- Rating, Year, Duration, Genre row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvRatingBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="#4CAF50"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvMetaInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#BBBBBB"
                            android:textSize="13sp"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Cast -->
                    <TextView
                        android:id="@+id/tvCast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone" />

                    <!-- Director -->
                    <TextView
                        android:id="@+id/tvDirector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone" />

                    <!-- Plot -->
                    <TextView
                        android:id="@+id/tvPlot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:maxLines="3"
                        android:ellipsize="end"
                        android:visibility="gone" />

                </LinearLayout>

            </FrameLayout>

            <!-- Search bar (hidden by default) -->
            <EditText
                android:id="@+id/etSearchBar"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="Search movies..."
                android:textColor="@color/white"
                android:textColorHint="@color/text_dim"
                android:textSize="14sp"
                android:background="@color/surface"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:visibility="gone" />

            <!-- Category name header -->
            <TextView
                android:id="@+id/tvCategoryHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <!-- Poster grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMovies"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="8dp" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/red"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/no_movies"
            android:textColor="@color/text_dim"
            android:textSize="16sp"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
